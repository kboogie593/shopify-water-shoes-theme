<section class="account-page">
  <div class="page-width">
    <header class="account-header">
      <div>
        <p class="eyebrow">Account</p>
        <h1>Welcome, {{ customer.first_name | default: customer.email }}</h1>
      </div>
      <a href="{{ routes.account_logout_url }}" class="btn btn--secondary">Log out</a>
    </header>

    <div class="account-grid">
      <aside class="account-sidebar">
        <h3>Menu</h3>
        <ul>
          <li><a href="{{ routes.account_url }}" class="account-nav-link active">Order history</a></li>
          <li><a href="{{ routes.account_addresses_url }}" class="account-nav-link">Addresses ({{ customer.addresses_count }})</a></li>
          <li><a href="{{ routes.account_logout_url }}" class="account-nav-link">Log out</a></li>
        </ul>

        <div class="account-promo">
          <strong>Free shipping over $79</strong>
          <p>Restock your favorites — and earn rewards on every order.</p>
          <a href="{{ routes.collections_url }}" class="btn btn--secondary" style="width:100%">Shop now</a>
        </div>
      </aside>

      <div class="account-main">
        <h2>Order history</h2>
        {%- if customer.orders.size > 0 -%}
          <div class="order-table">
            <div class="order-table__head">
              <div>Order</div>
              <div>Date</div>
              <div>Total</div>
              <div>Status</div>
              <div></div>
            </div>
            {%- for order in customer.orders -%}
              <div class="order-table__row">
                <div><strong>{{ order.name }}</strong></div>
                <div>{{ order.created_at | date: '%b %-d, %Y' }}</div>
                <div>{{ order.total_price | money }}</div>
                <div>
                  <span class="order-status order-status--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
                </div>
                <div><a href="{{ order.customer_url }}" class="account-link">View →</a></div>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="account-empty">
            <div class="account-empty__icon">📦</div>
            <h3>No orders yet</h3>
            <p>When you place your first order, it will show up here.</p>
            <a href="{{ routes.collections_url }}" class="btn">Browse water shoes</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
