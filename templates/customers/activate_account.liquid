<section class="auth-page">
  <div class="page-width">
    <div class="auth-card">
      <h1>Activate account</h1>
      <p class="auth-subtitle">Create a password to activate your account.</p>

      {%- form 'activate_customer_password', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-alert auth-alert--error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <label class="auth-field">
          <span>Password</span>
          <input type="password" name="customer[password]" required autocomplete="new-password" minlength="5">
        </label>

        <label class="auth-field">
          <span>Confirm password</span>
          <input type="password" name="customer[password_confirmation]" required autocomplete="new-password">
        </label>

        <button type="submit" class="btn btn--large">Activate</button>

        <div class="auth-links">
          <a href="{{ routes.account_logout_url }}">Decline invitation</a>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
