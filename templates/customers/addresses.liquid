<section class="account-page">
  <div class="page-width">
    <header class="account-header">
      <div>
        <p class="eyebrow">Account</p>
        <h1>Addresses</h1>
      </div>
      <a href="{{ routes.account_url }}" class="btn btn--secondary">Back to account</a>
    </header>

    {%- paginate customer.addresses by 6 -%}
      <div class="address-grid">
        {%- for address in customer.addresses -%}
          <div class="address-card{% if address == customer.default_address %} address-card--default{% endif %}">
            {%- if address == customer.default_address -%}
              <span class="address-card__badge">Default</span>
            {%- endif -%}
            <p>{{ address | format_address }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endpaginate -%}
  </div>
</section>
