<section class="auth-page">
  <div class="page-width">
    <div class="auth-card">
      <h1>Reset password</h1>
      <p class="auth-subtitle">Set a new password for your account.</p>

      {%- form 'reset_customer_password', class: 'auth-form' -%}
        {%- if form.errors -%}
          <div class="auth-alert auth-alert--error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <label class="auth-field">
          <span>New password</span>
          <input type="password" name="customer[password]" required autocomplete="new-password" minlength="5">
        </label>

        <label class="auth-field">
          <span>Confirm password</span>
          <input type="password" name="customer[password_confirmation]" required autocomplete="new-password">
        </label>

        <button type="submit" class="btn btn--large">Reset password</button>
      {%- endform -%}
    </div>
  </div>
</section>
