<section class="section-padding" style="background:#f0fdfa">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial" {{ block.shopify_attributes }}>
          <p class="testimonial-text">{{ block.settings.text }}</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">{{ block.settings.name | slice: 0, 1 }}</div>
            <div>
              <div class="testimonial-name">{{ block.settings.name }}</div>
              <div class="testimonial-role">{{ block.settings.role }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Early customer language"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Early language from real pet owners"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "The quiet-start routine is the part I need. I want less loose fur without turning grooming into a fight."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah K."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / Location",
          "default": "Apartment dog owner"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "text": "The quiet-start routine is the part I needed. I want less loose fur without turning grooming into a fight.",
            "name": "Sarah K.",
            "role": "Husky owner"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "I want one tool that makes brushing less stressful and leaves less loose fur on the sofa.",
            "name": "Marcus T.",
            "role": "Apartment dog owner"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "text": "If it cuts down the fur tumbleweeds after brushing, this is the type of tool I would keep by the mudroom.",
            "name": "Emma R.",
            "role": "Retriever household"
          }
        }
      ]
    }
  ]
}
{% endschema %}
