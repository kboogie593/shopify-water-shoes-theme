<section class="not-found">
  <div class="not-found__bg">
    <span class="bubble bubble--1"></span>
    <span class="bubble bubble--2"></span>
    <span class="bubble bubble--3"></span>
    <span class="bubble bubble--4"></span>
    <span class="bubble bubble--5"></span>
  </div>

  <div class="page-width not-found__inner">
    <div class="not-found__art" aria-hidden="true">
      <span class="not-found__shoe">✓</span>
      <svg class="not-found__wave" viewBox="0 0 600 80" preserveAspectRatio="none">
        <path d="M0,40 Q150,0 300,40 T600,40 V80 H0 Z" fill="rgba(45, 212, 191, 0.25)"/>
        <path d="M0,50 Q150,20 300,50 T600,50 V80 H0 Z" fill="rgba(45, 212, 191, 0.4)"/>
      </svg>
    </div>

    <div class="not-found__code">404</div>
    <h1 class="not-found__title">{{ section.settings.heading | default: 'This page wandered off' }}</h1>
    <p class="not-found__subtitle">
      {{ section.settings.subtitle | default: "The page you were looking for has been moved, renamed, or never existed. Try the grooming kit, quiet-start guide, or contact support." }}
    </p>

    <form action="{{ routes.search_url }}" method="get" role="search" class="not-found__search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" name="q" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="Search">
      <button type="submit">Search</button>
    </form>

    <div class="not-found__actions">
      <a href="{{ routes.root_url }}" class="btn btn--large">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Back to home
      </a>
      <a href="{{ routes.collections_url }}" class="btn btn--secondary btn--large">
        {{ 'general.404.link' | t }}
      </a>
    </div>

    <div class="not-found__quick">
      <span class="not-found__quick-label">Popular destinations</span>
      <div class="not-found__quick-links">
        <a href="{{ routes.all_products_collection_url }}">All Grooming Kits</a>
        <a href="{{ routes.collections_url }}/best-sellers">Best Sellers</a>
        <a href="{{ routes.collections_url }}/new-arrivals">New Arrivals</a>
        <a href="/pages/contact">Contact Support</a>
        <a href="/pages/size-guide">Size Guide</a>
      </div>
    </div>
  </div>
</section>

<style>
  .not-found {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px 120px;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(180deg, #f0fdfa 0%, #ccfbf1 100%);
  }

  .not-found__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .not-found__bg .bubble {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.9), rgba(45, 212, 191, 0.4));
    box-shadow: inset 0 -4px 8px rgba(15, 118, 110, 0.15);
    animation: bubble-rise 12s ease-in-out infinite;
  }
  .not-found__bg .bubble--1 { width: 28px; height: 28px; left: 8%; bottom: 10%; animation-delay: 0s; }
  .not-found__bg .bubble--2 { width: 56px; height: 56px; left: 18%; bottom: 4%; animation-delay: -2s; }
  .not-found__bg .bubble--3 { width: 42px; height: 42px; right: 14%; bottom: 14%; animation-delay: -4s; }
  .not-found__bg .bubble--4 { width: 72px; height: 72px; right: 6%; bottom: 2%; animation-delay: -6s; }
  .not-found__bg .bubble--5 { width: 32px; height: 32px; left: 50%; bottom: 8%; animation-delay: -8s; }

  @keyframes bubble-rise {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-40px) scale(1.1); opacity: 0.9; }
  }

  .not-found__inner {
    position: relative;
    max-width: 720px;
    z-index: 1;
  }

  .not-found__art {
    position: relative;
    height: 140px;
    margin-bottom: 16px;
  }
  .not-found__shoe {
    display: inline-block;
    font-size: 88px;
    animation: shoe-float 3s ease-in-out infinite;
    filter: drop-shadow(0 12px 24px rgba(15, 118, 110, 0.3));
  }
  @keyframes shoe-float {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50% { transform: translateY(-14px) rotate(4deg); }
  }
  .not-found__wave {
    position: absolute;
    bottom: 0; left: 50%;
    width: 240px;
    height: 30px;
    transform: translateX(-50%);
    animation: wave-pulse 3s ease-in-out infinite;
  }
  @keyframes wave-pulse {
    0%, 100% { transform: translateX(-50%) scaleX(1); opacity: 0.7; }
    50% { transform: translateX(-50%) scaleX(1.1); opacity: 1; }
  }

  .not-found__code {
    font-family: var(--font-heading);
    font-size: clamp(96px, 16vw, 168px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 50%, #134e4a 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 8px;
  }

  .not-found__title {
    font-size: clamp(24px, 3.5vw, 36px);
    margin-bottom: 14px;
    color: #134e4a;
    letter-spacing: -0.02em;
  }

  .not-found__subtitle {
    font-size: 17px;
    color: #475569;
    margin-bottom: 36px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }

  .not-found__search {
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 480px;
    margin: 0 auto 32px;
    padding: 6px 6px 6px 18px;
    background: #fff;
    border-radius: 999px;
    box-shadow: 0 18px 40px -16px rgba(15, 118, 110, 0.25);
    border: 1px solid rgba(15, 118, 110, 0.08);
  }
  .not-found__search svg { color: #94a3b8; flex-shrink: 0; }
  .not-found__search input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 15px;
    padding: 12px 4px;
    background: transparent;
    font-family: inherit;
  }
  .not-found__search button {
    background: var(--color-primary-dark);
    color: #fff;
    padding: 12px 22px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: background 0.2s, transform 0.2s;
  }
  .not-found__search button:hover {
    background: #134e4a;
    transform: translateY(-1px);
  }

  .not-found__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .not-found__quick {
    padding-top: 32px;
    border-top: 1px solid rgba(15, 118, 110, 0.12);
  }
  .not-found__quick-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-primary-dark);
    margin-bottom: 14px;
  }
  .not-found__quick-links {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .not-found__quick-links a {
    padding: 10px 18px;
    background: rgba(255,255,255,0.7);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    color: #134e4a;
    border: 1px solid rgba(15, 118, 110, 0.12);
    transition: all 0.2s;
  }
  .not-found__quick-links a:hover {
    background: var(--color-primary-dark);
    color: #fff;
    border-color: var(--color-primary-dark);
    transform: translateY(-2px);
  }
</style>

{% schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This page wandered off"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The page you were looking for has been moved, renamed, or never existed. Try the grooming kit, quiet-start guide, or contact support."
    }
  ]
}
{% endschema %}
