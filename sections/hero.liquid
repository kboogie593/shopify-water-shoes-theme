<section class="hero">
  <div class="page-width hero-inner">
    <div class="hero-content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hero-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <div class="hero-buttons">
        {%- if section.settings.button_label != blank -%}
          <a href="{% render 'safe-url', url: section.settings.button_link %}" class="btn btn--large">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{% render 'safe-url', url: section.settings.button_link_2 %}" class="btn btn--secondary btn--large">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_text != blank -%}
        <div class="hero-trust">
          <span class="stars">★★★★★</span>
          <span>{{ section.settings.trust_text }}</span>
        </div>
      {%- endif -%}
    </div>
    <div class="hero-image">
      {%- assign builtin_image = section.settings.builtin_image | default: 'furquiet-product-hero-ai.jpg' -%}
      {%- assign builtin_width = 1586 -%}
      {%- assign builtin_height = 992 -%}
      {%- case builtin_image -%}
        {%- when 'furquiet-kit-flatlay-ai.jpg' -%}
          {%- assign builtin_width = 1254 -%}
          {%- assign builtin_height = 1254 -%}
        {%- when 'furquiet-grooming-lifestyle-ai.jpg' -%}
          {%- assign builtin_width = 1448 -%}
          {%- assign builtin_height = 1086 -%}
        {%- when 'furquiet-clean-home-ai.jpg' -%}
          {%- assign builtin_width = 1672 -%}
          {%- assign builtin_height = 941 -%}
      {%- endcase -%}
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="eager">
      {%- else -%}
        <img
          src="{{ builtin_image | asset_url }}"
          alt="{{ section.settings.heading | default: 'FurQuiet pet grooming vacuum' | escape }}"
          width="{{ builtin_width }}"
          height="{{ builtin_height }}"
          loading="eager">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Quiet grooming kit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Vacuum loose fur while you brush."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "FurQuiet pairs a low-noise grooming vacuum with de-shedding tools, clipper support, washable filters, and a compact dock for heavy-shedding dogs and cats."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Custom image"
    },
    {
      "type": "select",
      "id": "builtin_image",
      "label": "Built-in fallback image",
      "options": [
        { "value": "furquiet-product-hero-ai.jpg", "label": "Product hero" },
        { "value": "furquiet-kit-flatlay-ai.jpg", "label": "Full kit flatlay" },
        { "value": "furquiet-grooming-lifestyle-ai.jpg", "label": "Lifestyle grooming" },
        { "value": "furquiet-clean-home-ai.jpg", "label": "Clean home comparison" },
        { "value": "furquiet-hero.png", "label": "Legacy hero" }
      ],
      "default": "furquiet-product-hero-ai.jpg"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button",
      "default": "Our Technology"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust line",
      "default": "Rated 4.8/5 by 50,000+ adventurers worldwide"
    }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
