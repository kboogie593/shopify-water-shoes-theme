<header class="site-header" data-site-header>
  {%- comment -%} ──── Row 1 : Logo + utility icons ──── {%- endcomment -%}
  <div class="page-width header-top">
    <a href="{{ routes.root_url }}" class="header-logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: section.settings.logo_width | times: 2 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          style="max-width: {{ section.settings.logo_width }}px"
          loading="eager">
      {%- else -%}
        {%- assign default_logo = section.settings.builtin_logo | default: 'furquiet-logo.svg' -%}
        <img
          src="{{ default_logo | asset_url }}"
          alt="{{ shop.name | default: 'FurQuiet' }}"
          width="{{ section.settings.logo_width }}"
          style="max-width: {{ section.settings.logo_width }}px"
          loading="eager">
      {%- endif -%}
    </a>

    <div class="header-actions">
      <button type="button" class="header-icon hide-mobile" aria-label="Search" data-search-open>
        {% render 'icon-search' %}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header-icon hide-mobile" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}
      <a href="/pages/wishlist" class="header-icon header-icon--wishlist hide-mobile" aria-label="Wishlist" data-wishlist-link>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span class="cart-count-bubble" data-wishlist-count-bubble hidden>0</span>
      </a>
      <button type="button" class="header-icon show-mobile" aria-label="Search" data-search-open>
        {% render 'icon-search' %}
      </button>
      {%- if settings.cart_type == 'drawer' -%}
        <button type="button" class="header-icon header-icon--cart" aria-label="Cart" data-cart-open>
          {% render 'icon-cart' %}
          <span class="cart-count-bubble" data-cart-count-bubble {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </button>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="header-icon header-icon--cart" aria-label="Cart">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}
            <span class="cart-count-bubble">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
      <button type="button" class="header-icon menu-toggle" aria-expanded="false" aria-label="Menu">
        {% render 'icon-menu' %}
      </button>
    </div>
  </div>

  {%- comment -%} ──── Row 2 : Navigation strip ──── {%- endcomment -%}
  <div class="header-nav-wrap">
    <nav class="page-width header-nav" aria-label="Main navigation">
      {%- comment -%}
        Decide which menu to render: built-in English (default) or the
        Shopify admin link_list (for power users who want to customize).
      {%- endcomment -%}
      {%- assign use_builtin = section.settings.use_builtin_menu -%}
      {%- if section.settings.menu.links.size == 0 -%}
        {%- assign use_builtin = true -%}
      {%- endif -%}

      {%- if use_builtin -%}
        {%- comment -%} Built-in FurQuiet navigation {%- endcomment -%}
        <a href="/" class="header-nav__link{% if request.path == '/' %} is-active{% endif %}">Home</a>

        <div class="header-nav__item has-submenu" data-mega-trigger>
          <a href="/collections/all" class="header-nav__link{% if request.path contains '/collections' %} is-active{% endif %}">
            Shop
            <svg class="header-nav__chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="mega-menu" data-mega-menu>
            <div class="page-width">
              <div class="mega-menu__grid">
                <div class="mega-menu__col">
                  <a href="{% render 'collection-url', handle: 'pet-grooming-vacuums' %}" class="mega-menu__heading">Grooming kits</a>
                  <ul>
                    <li><a href="/products/furquiet-grooming-vacuum-kit">FurQuiet Vacuum Kit</a></li>
                    <li><a href="{% render 'collection-url', handle: 'replacement-filters' %}">Replacement Filters</a></li>
                    <li><a href="{% render 'collection-url', handle: 'grooming-attachments' %}">Grooming Attachments</a></li>
                    <li><a href="{% render 'collection-url', handle: 'first-batch' %}">First Batch</a></li>
                  </ul>
                </div>
                <div class="mega-menu__col">
                  <a href="{% render 'collection-url', handle: 'shedding-dogs' %}" class="mega-menu__heading">By pet type</a>
                  <ul>
                    <li><a href="{% render 'collection-url', handle: 'husky-grooming' %}">Husky & Double Coat</a></li>
                    <li><a href="{% render 'collection-url', handle: 'german-shepherd-grooming' %}">German Shepherd</a></li>
                    <li><a href="{% render 'collection-url', handle: 'golden-retriever-grooming' %}">Golden Retriever</a></li>
                    <li><a href="{% render 'collection-url', handle: 'long-hair-cat-grooming' %}">Long-Hair Cats</a></li>
                  </ul>
                </div>
                <div class="mega-menu__col">
                  <a href="{% render 'collection-url', handle: 'home-grooming' %}" class="mega-menu__heading">By home</a>
                  <ul>
                    <li><a href="{% render 'collection-url', handle: 'apartment-pets' %}">Apartment Pets</a></li>
                    <li><a href="{% render 'collection-url', handle: 'nervous-pets' %}">Nervous Pets</a></li>
                    <li><a href="{% render 'collection-url', handle: 'multi-pet-homes' %}">Multi-Pet Homes</a></li>
                  </ul>
                </div>
                <div class="mega-menu__col">
                  <a href="/collections/all" class="mega-menu__heading">Shop All</a>
                  <ul>
                    <li><a href="/collections/all">All Products</a></li>
                    <li><a href="{% render 'collection-url', handle: 'best-sellers' %}">Best Sellers</a></li>
                    <li><a href="{% render 'collection-url', handle: 'new-arrivals' %}">New Arrivals</a></li>
                    <li><a href="{% render 'collection-url', handle: 'sale' %}">Sale</a></li>
                  </ul>
                </div>

                {%- if section.settings.mega_promo_image != blank -%}
                  <a href="{{ section.settings.mega_promo_link | default: '/collections/all' }}" class="mega-menu__promo">
                    <img src="{{ section.settings.mega_promo_image | image_url: width: 600 }}" alt="{{ section.settings.mega_promo_heading | escape }}" loading="lazy">
                    <div class="mega-menu__promo-body">
                      <strong>{{ section.settings.mega_promo_heading }}</strong>
                      <span>{{ section.settings.mega_promo_cta | default: 'Shop now →' }}</span>
                    </div>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>

        <a href="/pages/quiet-start-guide" class="header-nav__link{% if request.path == '/pages/quiet-start-guide' %} is-active{% endif %}">Quiet-start guide</a>
        <a href="/pages/faq" class="header-nav__link{% if request.path == '/pages/faq' %} is-active{% endif %}">FAQ</a>
        <a href="/blogs/news" class="header-nav__link{% if request.path contains '/blogs' %} is-active{% endif %}">Journal</a>
        <a href="/pages/about" class="header-nav__link{% if request.path == '/pages/about' %} is-active{% endif %}">About</a>
        <a href="/pages/contact" class="header-nav__link{% if request.path == '/pages/contact' %} is-active{% endif %}">Contact</a>
        <a href="/products/furquiet-grooming-vacuum-kit" class="header-nav__link is-promo">First Batch</a>

      {%- else -%}
        {%- comment -%} Custom Shopify menu {%- endcomment -%}
        {%- for link in section.settings.menu.links -%}
          {%- assign is_promo = false -%}
          {%- if link.title contains '🚀' or link.title contains '✨' or link.title contains '🔥' or link.title contains '⚡' -%}
            {%- assign is_promo = true -%}
          {%- endif -%}

          {%- if link.links.size > 0 -%}
            <div class="header-nav__item has-submenu" data-mega-trigger>
              <a href="{{ link.url }}" class="header-nav__link{% if link.active %} is-active{% endif %}{% if is_promo %} is-promo{% endif %}">
                {{ link.title }}
                <svg class="header-nav__chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
              <div class="mega-menu" data-mega-menu>
                <div class="page-width">
                  <div class="mega-menu__grid">
                    {%- for sublink in link.links -%}
                      <div class="mega-menu__col">
                        <a href="{{ sublink.url }}" class="mega-menu__heading">{{ sublink.title }}</a>
                        {%- if sublink.links.size > 0 -%}
                          <ul>
                            {%- for grandchild in sublink.links -%}
                              <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}

                    {%- if section.settings.mega_promo_image != blank -%}
                      <a href="{{ section.settings.mega_promo_link | default: '#' }}" class="mega-menu__promo">
                        <img src="{{ section.settings.mega_promo_image | image_url: width: 600 }}" alt="{{ section.settings.mega_promo_heading | escape }}" loading="lazy">
                        <div class="mega-menu__promo-body">
                          <strong>{{ section.settings.mega_promo_heading }}</strong>
                          <span>{{ section.settings.mega_promo_cta | default: 'Shop now →' }}</span>
                        </div>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header-nav__link{% if link.active %} is-active{% endif %}{% if is_promo %} is-promo{% endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Custom logo (overrides built-in)" },
    {
      "type": "select",
      "id": "builtin_logo",
      "label": "Built-in logo variant",
      "options": [
        { "value": "furquiet-logo.svg", "label": "FurQuiet — teal badge" },
        { "value": "furquiet-logo.png", "label": "Legacy text logo" },
        { "value": "furquiet-logo-with-palm.png", "label": "Legacy palm logo" }
      ],
      "default": "furquiet-logo.svg"
    },
    { "type": "range", "id": "logo_width", "min": 80, "max": 320, "step": 10, "unit": "px", "label": "Logo width", "default": 220 },
    {
      "type": "checkbox",
      "id": "use_builtin_menu",
      "label": "Use built-in English navigation",
      "info": "Uncheck to use a custom Shopify menu (Online Store → Navigation).",
      "default": true
    },
    { "type": "link_list", "id": "menu", "label": "Custom Shopify menu (only used when checkbox above is unchecked)", "default": "main-menu" },
    { "type": "header", "content": "Mega menu promo card" },
    { "type": "image_picker", "id": "mega_promo_image", "label": "Promo image" },
    { "type": "text", "id": "mega_promo_heading", "label": "Promo heading", "default": "First-batch grooming kit" },
    { "type": "text", "id": "mega_promo_cta", "label": "Promo CTA", "default": "Shop now →" },
    { "type": "url", "id": "mega_promo_link", "label": "Promo link" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
