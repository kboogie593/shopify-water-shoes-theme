<section class="section-padding" style="background:{{ section.settings.bg_color | default: '#f8fafc' }}">
  <div class="page-width">
    <div class="section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p>{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="features-grid">
      {%- for block in section.blocks -%}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-icon">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Engineered for everyday pet homes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why pet owners choose FurQuiet"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Built for calmer grooming, visible fur capture, and faster home cleanup."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f8fafc"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quiet-start grooming kit"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Give nervous pets distance, low airflow, and short sessions before brushing."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "heading": "Quiet-start routine",
            "text": "Give nervous pets distance, low airflow, and short sessions before brushing."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "heading": "Visible fur capture",
            "text": "Brush loose undercoat toward the dust cup before it spreads around the room."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "heading": "Small-home cleanup",
            "text": "Build the routine around sofas, rugs, bedding, clothing, and apartment storage."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "heading": "De-shedding support",
            "text": "Routine grooming support for heavy-shedding dogs and long-hair cats."
          }
        }
      ]
    }
  ]
}
{% endschema %}
