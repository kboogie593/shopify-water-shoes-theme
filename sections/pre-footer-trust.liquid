<section class="pre-footer-trust" style="background:{{ section.settings.bg_color | default: '#fff' }}">
  <div class="page-width">
    <div class="pre-footer-trust__grid" style="--cols:{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div class="pre-footer-trust__item js-reveal" {{ block.shopify_attributes }}>
          <div class="pre-footer-trust__badge">
            {%- case block.settings.icon -%}
              {%- when 'globe' -%}
                <svg viewBox="0 0 120 120" width="100" height="100" aria-hidden="true">
                  <circle cx="60" cy="60" r="42" fill="none" stroke="currentColor" stroke-width="4"/>
                  <ellipse cx="60" cy="60" rx="18" ry="42" fill="none" stroke="currentColor" stroke-width="4"/>
                  <line x1="18" y1="60" x2="102" y2="60" stroke="currentColor" stroke-width="4"/>
                  <path d="M85 22 Q104 22 100 38" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                  <polyline points="92,36 100,38 100,28" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- when 'stamp' -%}
                <svg viewBox="0 0 120 120" width="100" height="100" aria-hidden="true">
                  <circle cx="60" cy="60" r="46" fill="none" stroke="currentColor" stroke-width="3"/>
                  <circle cx="60" cy="60" r="38" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="3 4"/>
                  <text x="60" y="48" text-anchor="middle" font-family="Georgia, serif" font-size="11" font-weight="700" fill="currentColor" letter-spacing="2">SATISFIED</text>
                  <text x="60" y="68" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="900" fill="currentColor" letter-spacing="3">OR</text>
                  <text x="60" y="84" text-anchor="middle" font-family="Georgia, serif" font-size="10" font-weight="700" fill="currentColor" letter-spacing="2">REFUNDED</text>
                </svg>
              {%- when 'service' -%}
                <svg viewBox="0 0 120 120" width="100" height="100" aria-hidden="true">
                  <circle cx="60" cy="60" r="46" fill="none" stroke="currentColor" stroke-width="3"/>
                  <text x="60" y="46" text-anchor="middle" font-family="Georgia, serif" font-size="9" font-weight="700" fill="currentColor" letter-spacing="2.5">SERVICE</text>
                  <text x="60" y="72" text-anchor="middle" font-family="Georgia, serif" font-size="22" font-weight="900" fill="currentColor" letter-spacing="3">CARE</text>
                  <text x="60" y="88" text-anchor="middle" font-family="Georgia, serif" font-size="9" font-weight="700" fill="currentColor" letter-spacing="2.5">7 DAYS</text>
                </svg>
              {%- when 'secure' -%}
                <svg viewBox="0 0 120 120" width="100" height="100" aria-hidden="true">
                  <rect x="22" y="38" width="60" height="44" rx="6" fill="none" stroke="currentColor" stroke-width="4"/>
                  <line x1="22" y1="52" x2="82" y2="52" stroke="currentColor" stroke-width="4"/>
                  <line x1="32" y1="68" x2="50" y2="68" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                  <rect x="62" y="56" width="32" height="34" rx="6" fill="none" stroke="currentColor" stroke-width="4"/>
                  <path d="M70 56 Q70 44 78 44 Q86 44 86 56" fill="none" stroke="currentColor" stroke-width="4"/>
                  <circle cx="78" cy="72" r="3" fill="currentColor"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 120 120" width="100" height="100" aria-hidden="true">
                  <circle cx="60" cy="60" r="42" fill="none" stroke="currentColor" stroke-width="4"/>
                  <polyline points="44,60 56,72 78,48" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            {%- endcase -%}
          </div>
          <p class="pre-footer-trust__label">{{ block.settings.label }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%}
    Animated ocean — 3 stacked wave layers sliding at different
    speeds (parallax), with a slow color-cycle between the
    footer color and a lighter sky-blue.  Plus bubble particles.
  {%- endcomment -%}
  <div class="ocean" aria-hidden="true">
    <svg class="ocean__svg" viewBox="0 0 2880 120" preserveAspectRatio="none">
      {%- comment -%} Back wave — slowest, most transparent {%- endcomment -%}
      <path class="ocean__wave ocean__wave--back" d="M0,60 C360,30 720,90 1080,60 C1440,30 1800,90 2160,60 C2520,30 2880,90 2880,60 L2880,120 L0,120 Z"/>
      {%- comment -%} Middle wave — medium speed {%- endcomment -%}
      <path class="ocean__wave ocean__wave--mid" d="M0,70 C240,40 480,100 720,70 C960,40 1200,100 1440,70 C1680,40 1920,100 2160,70 C2400,40 2640,100 2880,70 L2880,120 L0,120 Z"/>
      {%- comment -%} Front wave — fastest, fully opaque {%- endcomment -%}
      <path class="ocean__wave ocean__wave--front" d="M0,80 C180,55 360,105 540,80 C720,55 900,105 1080,80 C1260,55 1440,105 1620,80 C1800,55 1980,105 2160,80 C2340,55 2520,105 2700,80 C2790,68 2880,92 2880,80 L2880,120 L0,120 Z"/>
    </svg>

    {%- comment -%} Bubble particles floating up through the water {%- endcomment -%}
    <span class="ocean__bubble" style="left:6%;  width:8px;  height:8px;  animation-duration:7s;  animation-delay:0s;"></span>
    <span class="ocean__bubble" style="left:14%; width:14px; height:14px; animation-duration:9s;  animation-delay:-2s;"></span>
    <span class="ocean__bubble" style="left:22%; width:6px;  height:6px;  animation-duration:6s;  animation-delay:-1s;"></span>
    <span class="ocean__bubble" style="left:34%; width:10px; height:10px; animation-duration:8s;  animation-delay:-4s;"></span>
    <span class="ocean__bubble" style="left:46%; width:18px; height:18px; animation-duration:11s; animation-delay:-3s;"></span>
    <span class="ocean__bubble" style="left:58%; width:8px;  height:8px;  animation-duration:7.5s;animation-delay:-5s;"></span>
    <span class="ocean__bubble" style="left:70%; width:12px; height:12px; animation-duration:9s;  animation-delay:-6s;"></span>
    <span class="ocean__bubble" style="left:82%; width:6px;  height:6px;  animation-duration:7s;  animation-delay:-2s;"></span>
    <span class="ocean__bubble" style="left:92%; width:16px; height:16px; animation-duration:10s; animation-delay:-7s;"></span>
  </div>
</section>

<style>
  .pre-footer-trust {
    padding: 80px 0 120px;
    position: relative;
    overflow: hidden;
  }
  .pre-footer-trust__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr));
    gap: 40px;
    align-items: start;
  }
  .pre-footer-trust__item {
    text-align: center;
    color: var(--color-foreground);
    transition: transform 0.4s cubic-bezier(.2,.8,.2,1);
  }
  .pre-footer-trust__item:hover { transform: translateY(-8px); }
  .pre-footer-trust__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    margin-bottom: 18px;
    transition: color 0.3s;
  }
  .pre-footer-trust__item:hover .pre-footer-trust__badge {
    color: var(--color-primary-dark);
    animation: bob 0.6s ease;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px) rotate(-3deg); }
  }
  .pre-footer-trust__label {
    color: var(--color-primary-dark);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.2px;
    margin: 0;
  }
  /* ====== Animated ocean wave ====== */
  .ocean {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    width: 100%;
    height: 130px;
    pointer-events: none;
    overflow: hidden;
  }
  .ocean__svg {
    position: absolute;
    bottom: 0; left: 0;
    width: 200%;
    height: 100%;
    display: block;
    /* color cycle: footer color → light sky-blue → back, ~14s */
    animation: ocean-color 14s ease-in-out infinite alternate;
    color: {{ section.settings.wave_color | default: '#0F766E' }};
  }
  .ocean__wave {
    fill: currentColor;
    will-change: transform;
  }
  .ocean__wave--back {
    opacity: 0.35;
    animation: wave-slide-rev 26s linear infinite;
  }
  .ocean__wave--mid {
    opacity: 0.6;
    animation: wave-slide 18s linear infinite;
    transform: translateX(-720px);
  }
  .ocean__wave--front {
    opacity: 1;
    animation: wave-slide 12s linear infinite;
  }

  @keyframes wave-slide {
    from { transform: translateX(0); }
    to   { transform: translateX(-1440px); }
  }
  /* Mid wave starts offset so layers don't sync */
  @keyframes wave-slide-mid {
    from { transform: translateX(-720px); }
    to   { transform: translateX(-2160px); }
  }
  @keyframes wave-slide-rev {
    from { transform: translateX(-1440px); }
    to   { transform: translateX(0); }
  }

  @keyframes ocean-color {
    0%   { color: {{ section.settings.wave_color | default: '#0F766E' }}; }
    50%  { color: #38bdf8; }   /* sky-400 — bright water */
    100% { color: #7dd3fc; }   /* sky-300 — pale water */
  }

  /* Use the middle keyframes explicitly */
  .ocean__wave--mid { animation-name: wave-slide-mid; }

  /* ====== Bubbles ====== */
  .ocean__bubble {
    position: absolute;
    bottom: -20px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.95), rgba(255,255,255,0.35));
    box-shadow: inset 0 -1px 2px rgba(15, 118, 110, 0.25);
    opacity: 0;
    animation: bubble-rise 8s ease-in-out infinite;
    will-change: transform, opacity;
  }
  @keyframes bubble-rise {
    0%   { transform: translateY(0) scale(0.6); opacity: 0; }
    10%  { opacity: 0.85; }
    50%  { transform: translateY(-80px) translateX(-6px) scale(1.05); opacity: 0.95; }
    100% { transform: translateY(-160px) translateX(8px) scale(0.7); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ocean__wave, .ocean__svg, .ocean__bubble { animation: none !important; }
  }

  @media (max-width: 900px) {
    .pre-footer-trust__grid { grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .ocean { height: 90px; }
  }
  @media (max-width: 480px) {
    .pre-footer-trust__grid { grid-template-columns: 1fr; }
    .pre-footer-trust { padding: 56px 0 100px; }
    .ocean { height: 70px; }
  }
</style>

{% schema %}
{
  "name": "Pre-footer trust",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "color", "id": "wave_color", "label": "Wave color (should match footer)", "default": "#0F766E" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Badge icon",
          "options": [
            { "value": "globe", "label": "Globe (international delivery)" },
            { "value": "stamp", "label": "Satisfied or refunded stamp" },
            { "value": "service", "label": "After-sales service stamp" },
            { "value": "secure", "label": "Secure payment lock" },
            { "value": "check", "label": "Check mark" }
          ],
          "default": "globe"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "International Delivery" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "badge", "settings": { "icon": "globe",   "label": "International Delivery" } },
      { "type": "badge", "settings": { "icon": "stamp",   "label": "Satisfaction Guaranteed or Your Money Back" } },
      { "type": "badge", "settings": { "icon": "service", "label": "After-Sales Service" } },
      { "type": "badge", "settings": { "icon": "secure",  "label": "Secure Payment" } }
    ]
  },
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
