<section class="collection-header">
  <div class="page-width">
    {% render 'breadcrumb' %}
    <h1>{{ collection.title | default: 'All products' }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description }}</p>
    {%- endif -%}
  </div>
</section>

<section class="collection-body">
  <div class="page-width">
    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="collection-toolbar">
        <span class="collection-toolbar__count">{{ collection.products_count }} products</span>

        <button type="button" class="collection-toolbar__filter-toggle" data-facet-toggle>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
          Filter
        </button>

        <form class="collection-toolbar__sort">
          {%- comment -%} Preserve filter params when changing sort {%- endcomment -%}
          {%- for filter in collection.filters -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != null -%}
                <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | strip }}">
              {%- endif -%}
              {%- if filter.max_value.value != null -%}
                <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | strip }}">
              {%- endif -%}
            {%- else -%}
              {%- for value in filter.active_values -%}
                <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}

          <label for="SortBy">Sort by</label>
          <select id="SortBy" name="sort_by" onchange="this.form.submit()">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <option value="manual" {% if sort_by == 'manual' %}selected{% endif %}>Featured</option>
            <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>Best selling</option>
            <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>Name A-Z</option>
            <option value="title-descending" {% if sort_by == 'title-descending' %}selected{% endif %}>Name Z-A</option>
            <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price low to high</option>
            <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price high to low</option>
            <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest first</option>
          </select>
        </form>
      </div>

      <div class="collection-layout">
        <aside class="collection-sidebar" data-facet-drawer>
          <header class="collection-sidebar__header">
            <h2>Filters</h2>
            <button type="button" class="collection-sidebar__close" data-facet-close aria-label="Close filters">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </header>
          <div class="collection-sidebar__body">
            {% render 'facets' %}
          </div>
        </aside>

        <div class="collection-main">
          {%- if collection.products.size > 0 -%}
            <div class="product-grid">
              {%- for product in collection.products -%}
                {% render 'product-card', product: product %}
              {%- endfor -%}
            </div>

            {% render 'pagination', paginate: paginate %}
          {%- else -%}
            <div class="collection-empty">
              <div class="collection-empty__icon">🔍</div>
              <h3>No products match your filters</h3>
              <p>Try removing a filter or browse the full collection.</p>
              <a href="{{ collection.url }}" class="btn btn--secondary">Clear all filters</a>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endpaginate -%}
  </div>
</section>

<div class="facet-overlay" data-facet-overlay></div>

{% schema %}
{
  "name": "Collection products",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
