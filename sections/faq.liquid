<section class="section-padding faq-section">
  <div class="page-width">
    <div class="faq-layout">
      <div class="faq-intro">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p>{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="btn btn--secondary mt-4">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>

      <div class="faq-list">
        {%- for block in section.blocks -%}
          <details class="faq-item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary>
              <span>{{ block.settings.question }}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Questions, answered"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you wanted to know"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real answers from real customers. Still curious? Our team replies to every email within one business day."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Contact support"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What are pet grooming vacuums used for?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "A pet grooming vacuum helps brush loose fur while suction collects hair into a dust cup."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What are pet grooming vacuums used for?",
            "answer": "A pet grooming vacuum helps brush loose fur while suction collects hair into a dust cup. It is useful for heavy-shedding homes that want less loose fur on sofas, floors, bedding, and clothes."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Will a nervous pet tolerate FurQuiet?",
            "answer": "Some pets need a gradual introduction. Start several feet away, use the lowest setting, reward calm behavior, and only move closer when the pet is comfortable."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Which pets is this best for?",
            "answer": "FurQuiet is positioned for long-hair cats and shedding dogs such as huskies, German shepherds, golden retrievers, corgis, Samoyeds, and mixed breeds with heavy seasonal undercoat."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Does this replace a professional groomer?",
            "answer": "No. FurQuiet is for routine at-home brushing, trimming support, and fur cleanup between professional grooming visits. It is not a replacement for medical skin care, difficult mat removal, or breed-specific grooming."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How do I clean the filter and dust cup?",
            "answer": "Empty the dust cup after each grooming session. Wash reusable filter parts only when the product instructions say they are washable, and let every part dry completely before reinstalling."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "The launch plan uses a 30-day home trial, subject to final supplier, packaging, compliance, and fulfillment confirmation before checkout opens."
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Where does FurQuiet ship?",
            "answer": "FurQuiet is planned first for the United States, Canada, the United Kingdom, and Australia."
          }
        }
      ]
    }
  ]
}
{% endschema %}
