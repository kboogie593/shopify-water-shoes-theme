<section class="section-padding stats-section">
  <div class="page-width">
    <div class="stats-grid">
      {%- for block in section.blocks -%}
        <div class="stat-item" {{ block.shopify_attributes }}>
          <div class="stat-value">{{ block.settings.value }}</div>
          <div class="stat-label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats bar",
  "settings": [],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "First"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Sample QA gate"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats bar",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "First",
            "label": "production batch"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "QA",
            "label": "sample test gate"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "60-day",
            "label": "Try-anywhere guarantee"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "FREE",
            "label": "Shipping over $79"
          }
        }
      ]
    }
  ]
}
{% endschema %}
