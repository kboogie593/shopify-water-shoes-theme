{%- comment -%}
  GEO (Generative Engine Optimization) structured data.
  Emits JSON-LD schema.org markup so AI search engines (ChatGPT,
  Perplexity, Google AI Overviews, Bing Copilot, Claude) can
  understand and cite your store with rich context.
{%- endcomment -%}

{%- liquid
  assign org_name = shop.name
  assign org_url = shop.url
  assign org_logo = settings.logo | image_url: width: 512
  if org_logo == blank
    assign org_logo = ''
  endif
-%}

{%- comment -%} Organization + WebSite (sitewide) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ org_url }}#organization",
      "name": {{ org_name | json }},
      "url": "{{ org_url }}",
      {% if org_logo != blank %}"logo": "https:{{ org_logo }}",{% endif %}
      "description": {{ shop.description | default: 'FurQuiet designs quiet-start pet grooming vacuum kits for heavy-shedding dogs, long-hair cats, and small homes that need calmer brushing and cleaner rooms.' | json }},
      "sameAs": [
        {%- assign social_list = '' -%}
        {%- if settings.social_instagram_link != blank -%}{%- assign social_list = social_list | append: settings.social_instagram_link | append: '|' -%}{%- endif -%}
        {%- if settings.social_facebook_link != blank -%}{%- assign social_list = social_list | append: settings.social_facebook_link | append: '|' -%}{%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}{%- assign social_list = social_list | append: settings.social_tiktok_link | append: '|' -%}{%- endif -%}
        {%- if settings.social_youtube_link != blank -%}{%- assign social_list = social_list | append: settings.social_youtube_link | append: '|' -%}{%- endif -%}
        {%- if settings.social_twitter_link != blank -%}{%- assign social_list = social_list | append: settings.social_twitter_link | append: '|' -%}{%- endif -%}
        {%- assign social_list = social_list | split: '|' -%}
        {%- for s in social_list -%}{{ s | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "support@furquiet.com",
        "availableLanguage": ["English"]
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{ org_url }}#website",
      "url": "{{ org_url }}",
      "name": {{ org_name | json }},
      "publisher": { "@id": "{{ org_url }}#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ org_url }}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
</script>

{%- comment -%} Product schema {%- endcomment -%}
{%- if template contains 'product' and product -%}
  {%- assign product_price = product.selected_or_first_available_variant.price | divided_by: 100.0 -%}
  {%- assign product_currency = cart.currency.iso_code -%}
  {%- assign product_schema_fallback_image = 'furquiet-product-hero-ai.jpg' | asset_url | prepend: 'https:' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "image": [
      {%- if product.media.size > 0 -%}
        {%- for media in product.media limit: 6 -%}
          "https:{{ media | image_url: width: 1200 }}"{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- else -%}
        {{ product_schema_fallback_image | json }}
      {%- endif -%}
    ],
    "description": {{ product.description | strip_html | truncate: 5000 | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
    "mpn": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "category": {{ product.type | default: 'Pet Grooming Vacuums' | json }},
    "offers": {
      "@type": "Offer",
      "url": "{{ shop.url }}{{ product.url }}",
      "priceCurrency": "{{ product_currency }}",
      "price": "{{ product_price }}",
      "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
    }
  }
  </script>
{%- endif -%}

{%- comment -%} Article schema {%- endcomment -%}
{%- if template contains 'article' and article -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ article.title | json }},
    "image": [{% if article.image %}"https:{{ article.image | image_url: width: 1600 }}"{% endif %}],
    "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
    "dateModified": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
    "author": { "@type": "Person", "name": {{ article.author | default: shop.name | json }} },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}{% if settings.logo %},
      "logo": { "@type": "ImageObject", "url": "https:{{ settings.logo | image_url: width: 512 }}" }{% endif %}
    },
    "description": {{ article.excerpt_or_content | strip_html | truncate: 300 | json }},
    "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ shop.url }}{{ article.url }}" }
  }
  </script>
{%- endif -%}

{%- comment -%} Collection / list page schema {%- endcomment -%}
{%- if template contains 'collection' and collection -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    "description": {{ collection.description | strip_html | default: collection.title | json }},
    "url": "{{ shop.url }}{{ collection.url }}",
    "hasPart": [
      {%- for product in collection.products limit: 12 -%}
        {
          "@type": "Product",
          "name": {{ product.title | json }},
          "url": "{{ shop.url }}{{ product.url }}",
          "image": "https:{{ product.featured_media | image_url: width: 800 }}",
          "offers": {
            "@type": "Offer",
            "price": "{{ product.price | divided_by: 100.0 }}",
            "priceCurrency": "{{ cart.currency.iso_code }}"
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{%- comment -%} Breadcrumbs {%- endcomment -%}
{%- if template contains 'product' and product -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "Shop", "item": "{{ shop.url }}/collections/all" },
      { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": "{{ shop.url }}{{ product.url }}" }
    ]
  }
  </script>
{%- elsif template contains 'collection' and collection -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}/" },
      { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": "{{ shop.url }}{{ collection.url }}" }
    ]
  }
  </script>
{%- endif -%}

{%- comment -%} FAQ schema for index / about pages {%- endcomment -%}
{%- if template == 'index' or template contains 'page' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a pet grooming vacuum used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A pet grooming vacuum helps brush loose fur while suction collects hair into a dust cup. It is useful for heavy-shedding homes that want less loose fur on sofas, floors, bedding, and clothes."
        }
      },
      {
        "@type": "Question",
        "name": "Will a nervous pet tolerate FurQuiet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Some pets need a gradual introduction. Start several feet away, use the lowest setting, reward calm behavior, and only move closer when the pet is comfortable."
        }
      },
      {
        "@type": "Question",
        "name": "Which pets is FurQuiet best for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FurQuiet is positioned for long-hair cats and shedding dogs such as huskies, German shepherds, golden retrievers, corgis, Samoyeds, and mixed breeds with heavy seasonal undercoat."
        }
      },
      {
        "@type": "Question",
        "name": "Does FurQuiet replace a professional groomer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. FurQuiet is for routine at-home brushing, trimming support, and fur cleanup between professional grooming visits. It is not a replacement for medical skin care, difficult mat removal, or breed-specific grooming."
        }
      },
      {
        "@type": "Question",
        "name": "How do I clean the filter and dust cup?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Empty the dust cup after each grooming session. Wash reusable filter parts only when the product instructions say they are washable, and let every part dry completely before reinstalling."
        }
      },
      {
        "@type": "Question",
        "name": "What is your return policy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The launch plan uses a 30-day home trial, subject to final supplier, packaging, compliance, and fulfillment confirmation before checkout opens."
        }
      },
      {
        "@type": "Question",
        "name": "Where does FurQuiet ship?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FurQuiet is planned first for the United States, Canada, the United Kingdom, and Australia."
        }
      }
    ]
  }
  </script>
{%- endif -%}
