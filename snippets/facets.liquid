<form data-facet-form method="get" class="facets">
  {%- comment -%} Preserve sort_by across filter changes {%- endcomment -%}
  {%- if collection.sort_by != blank -%}
    <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
  {%- endif -%}

  {%- comment -%} Active filter chips {%- endcomment -%}
  {%- assign has_active = false -%}
  {%- for filter in collection.filters -%}
    {%- if filter.type == 'price_range' and filter.min_value.value != null or filter.max_value.value != null -%}
      {%- assign has_active = true -%}
    {%- endif -%}
    {%- for value in filter.active_values -%}
      {%- assign has_active = true -%}
    {%- endfor -%}
  {%- endfor -%}

  {%- if has_active -%}
    <div class="facets__active">
      <span class="facets__active-label">Filters:</span>
      <ul class="facets__chips">
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != null or filter.max_value.value != null -%}
              <li>
                <a href="{{ filter.url_to_remove }}" class="filter-chip">
                  {{ filter.label }}: {{ filter.min_value.value | default: 0 | money }} – {{ filter.max_value.value | default: filter.range_max | money }}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </a>
              </li>
            {%- endif -%}
          {%- else -%}
            {%- for value in filter.active_values -%}
              <li>
                <a href="{{ value.url_to_remove }}" class="filter-chip">
                  {{ filter.label }}: {{ value.label }}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </a>
              </li>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </ul>
      <a href="{{ collection.url }}" class="facets__clear">Clear all</a>
    </div>
  {%- endif -%}

  {%- if collection.filters.size > 0 -%}
    {%- for filter in collection.filters -%}
      <details class="filter-group" open>
        <summary>
          <span>{{ filter.label }}</span>
          <svg class="filter-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="filter-group__body">
          {%- case filter.type -%}
            {%- when 'price_range' -%}
              <div class="filter-price">
                <div class="filter-price__inputs">
                  <label>
                    <span>Min</span>
                    <input
                      type="number"
                      name="{{ filter.min_value.param_name }}"
                      value="{{ filter.min_value.value | money_without_currency | strip_html | strip }}"
                      placeholder="{{ 0 | money_without_currency | strip }}"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | strip }}">
                  </label>
                  <span aria-hidden="true">–</span>
                  <label>
                    <span>Max</span>
                    <input
                      type="number"
                      name="{{ filter.max_value.param_name }}"
                      value="{{ filter.max_value.value | money_without_currency | strip_html | strip }}"
                      placeholder="{{ filter.range_max | money_without_currency | strip }}"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | strip }}">
                  </label>
                </div>
                <p class="filter-price__hint">Range: {{ 0 | money }} – {{ filter.range_max | money }}</p>
              </div>

            {%- when 'boolean' -%}
              {%- for value in filter.true_value, filter.false_value -%}
                <label class="filter-option">
                  <input
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}>
                  <span class="filter-option__label">{{ value.label }}</span>
                  <span class="filter-option__count">{{ value.count }}</span>
                </label>
              {%- endfor -%}

            {%- else -%}
              {%- comment -%} list filter (color, size, vendor, etc.) {%- endcomment -%}
              {%- assign is_color = false -%}
              {%- assign lower_label = filter.label | downcase -%}
              {%- if lower_label contains 'color' or lower_label contains 'colour' -%}
                {%- assign is_color = true -%}
              {%- endif -%}

              {%- if is_color -%}
                <div class="filter-swatches">
                  {%- for value in filter.values -%}
                    <label class="filter-swatch{% if value.count == 0 and value.active == false %} is-disabled{% endif %}" title="{{ value.label }} ({{ value.count }})">
                      <input
                        type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                      <span class="filter-swatch__color" style="background: {{ value.label | downcase | replace: ' ', '' }};"></span>
                      <span class="filter-swatch__label">{{ value.label }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <ul class="filter-options">
                  {%- for value in filter.values -%}
                    <li>
                      <label class="filter-option{% if value.count == 0 and value.active == false %} is-disabled{% endif %}">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                        <span class="filter-option__check" aria-hidden="true">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                        <span class="filter-option__label">{{ value.label }}</span>
                        <span class="filter-option__count">{{ value.count }}</span>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
          {%- endcase -%}
        </div>
      </details>
    {%- endfor -%}
  {%- else -%}
    <div class="facets__empty">
      <p>No filters configured yet.</p>
      <p class="facets__empty-hint">Install the <strong>Search &amp; Discovery</strong> app in your Shopify admin and add filters to enable this panel.</p>
    </div>
  {%- endif -%}

  <noscript>
    <button type="submit" class="btn">Apply filters</button>
  </noscript>
</form>
