<div class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__text">
      <strong>We use cookies.</strong>
      <span>To improve your browsing experience, analyze site traffic, and personalize content. By clicking &quot;Accept all&quot;, you consent to our use of cookies.</span>
    </div>
    <div class="cookie-banner__actions">
      <button type="button" class="btn btn--secondary" data-cookie-action="reject">Reject</button>
      <button type="button" class="btn" data-cookie-action="accept">Accept all</button>
    </div>
  </div>
</div>
