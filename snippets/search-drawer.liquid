<search-drawer class="search-drawer" data-search-drawer aria-hidden="true">
  <div class="search-drawer__overlay" data-search-close></div>

  <div class="search-drawer__panel" role="dialog" aria-modal="true" aria-label="Search">
    <form action="{{ routes.search_url }}" method="get" class="search-drawer__form" role="search">
      <svg class="search-drawer__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        type="search"
        name="q"
        autocomplete="off"
        placeholder="{{ 'general.search.placeholder' | t }}"
        aria-label="Search"
        data-search-input
        required>
      <button type="button" class="search-drawer__close" data-search-close aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </form>

    <div class="search-drawer__results" data-search-results>
      <div class="search-drawer__hint">
        <span class="eyebrow">Popular searches</span>
        <div class="search-drawer__suggestions">
          <a href="{{ routes.search_url }}?q=pet+grooming+vacuum">pet grooming vacuum</a>
          <a href="{{ routes.search_url }}?q=dog+shedding">dog shedding</a>
          <a href="{{ routes.search_url }}?q=quiet+grooming">quiet grooming</a>
          <a href="{{ routes.search_url }}?q=cat+grooming">cat grooming</a>
          <a href="{{ routes.search_url }}?q=replacement+filter">replacement filter</a>
        </div>
      </div>
    </div>
  </div>
</search-drawer>
