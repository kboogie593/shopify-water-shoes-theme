{%- comment -%}
  Smart collection URL resolver.

  Usage:
    <a href="{% render 'collection-url', handle: 'womens-water-shoes' %}">…</a>

  Returns:
    /collections/<handle>            if the collection exists
    /collections/all                 as a graceful fallback so the link
                                     never produces a 404
{%- endcomment -%}
{%- if collections[handle].id != blank -%}/collections/{{ handle }}{%- else -%}/collections/all{%- endif -%}
